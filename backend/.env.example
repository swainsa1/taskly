# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: SQLite file (no auth token needed)
DATABASE_URL=file:./db/taskly.sqlite

# Production (Turso): uncomment and fill in after running `turso db create taskly`
# DATABASE_URL=libsql://your-db-name-orgname.turso.io
# TURSO_AUTH_TOKEN=your-token-here

# ── Auth ─────────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword

# ── CORS (for production deployment) ─────────────────────────────────────────
# FRONTEND_URL=https://taskly-frontend.vercel.app
