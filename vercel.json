{
  "version": 2,
  "buildCommand": "npm install --include=dev --prefix frontend && npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/api/index.py": {
      "runtime": "python3.11",
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/backend/api/index.py" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
